[gd_scene load_steps=1 format=3]

[node name="PageCodex" type="VBoxContainer"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_right = 0.0
offset_bottom = 0.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 0
size_flags_horizontal = 3
size_flags_vertical = 3

[node name="CodexTop" type="HBoxContainer" parent="."]
visible = false
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 10

[node name="TitleBlock" type="VBoxContainer" parent="CodexTop"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 4

[node name="SessionPicker" type="OptionButton" parent="CodexTop/TitleBlock"]
layout_mode = 2
custom_minimum_size = Vector2(220, 0)

[node name="ConversationPanel" type="PanelContainer" parent="."]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3

[node name="ConversationScroll" type="ScrollContainer" parent="ConversationPanel"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
follow_focus = true

[node name="ConversationList" type="VBoxContainer" parent="ConversationPanel/ConversationScroll"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 12

[node name="ComposerMargin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 0
theme_override_constants/margin_top = 8
theme_override_constants/margin_right = 0
theme_override_constants/margin_bottom = 0

[node name="ComposerPanel" type="PanelContainer" parent="ComposerMargin"]
custom_minimum_size = Vector2(0, 160)
layout_mode = 2
size_flags_horizontal = 3

[node name="Composer" type="VBoxContainer" parent="ComposerMargin/ComposerPanel"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 4

[node name="PromptEdit" type="TextEdit" parent="ComposerMargin/ComposerPanel/Composer"]
custom_minimum_size = Vector2(0, 100)
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "Ask Orbit to inspect, propose, or prepare a change..."
wrap_mode = 1

[node name="ComposerFooter" type="HBoxContainer" parent="ComposerMargin/ComposerPanel/Composer"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 8

[node name="AddContextButton" type="Button" parent="ComposerMargin/ComposerPanel/Composer/ComposerFooter"]
layout_mode = 2
flat = true

[node name="ProviderSelect" type="OptionButton" parent="ComposerMargin/ComposerPanel/Composer/ComposerFooter"]
layout_mode = 2
custom_minimum_size = Vector2(140, 0)
flat = true

[node name="ContextToggle" type="Button" parent="ComposerMargin/ComposerPanel/Composer/ComposerFooter"]
layout_mode = 2
toggle_mode = true
button_pressed = true
text = "IDE Context"
flat = true

[node name="Spacer" type="Control" parent="ComposerMargin/ComposerPanel/Composer/ComposerFooter"]
layout_mode = 2
size_flags_horizontal = 3

[node name="ValidationBadge" type="Label" parent="ComposerMargin/ComposerPanel/Composer/ComposerFooter"]
visible = false
layout_mode = 2
vertical_alignment = 1
text = "Validation pending"

[node name="ComposerActions" type="HBoxContainer" parent="ComposerMargin/ComposerPanel/Composer/ComposerFooter"]
layout_mode = 2
alignment = 2
theme_override_constants/separation = 4

[node name="SendPromptButton" type="Button" parent="ComposerMargin/ComposerPanel/Composer/ComposerFooter/ComposerActions"]
layout_mode = 2
custom_minimum_size = Vector2(32, 32)
